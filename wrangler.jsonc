{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "site",
  "main": "src/index.js",
  "compatibility_date": "2026-04-09",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "node build.js"
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
